# ──────────────────────────────────────────────
#  Unity .gitignore
# ──────────────────────────────────────────────

# Generated by Unity — always rebuilt locally, never commit
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures (large profiling files)
/[Mm]emory[Cc]aptures/

# Asset meta data should only be ignored when the Assets directory is ignored entirely
!/[Aa]ssets/**/*.meta

# Autogenerated VS/Rider project files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/**/*.bin*

# Streaming assets (optional — remove if you want to track them)
# /[Aa]ssets/[Ss]treamingAssets/

# Third-party asset packages (large textures, not your work)
/[Aa]ssets/[Ss]tarfield [Ss]kybox/

# JetBrains Rider
.idea/
*.sln.DotSettings.user

# Visual Studio
.vs/
*.vcxproj
*.vcxproj.filters

# macOS
.DS_Store

# Windows
Thumbs.db
Desktop.ini

# Log files
*.log
